{
  "name": "jean-michel-volume",
  "version": "2.0.2",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "sharp"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prelint": "next typegen",
    "lint": "bun run tsc && bun run biome:check && bun run biome:format",
    "tsc": "tsc --noEmit --pretty",
    "biome:check": "biome check .",
    "biome:check:write": "biome check --write .",
    "biome:format:write": "biome format --write .",
    "biome:format": "biome format .",
    "biome:write": "biome check --write . && biome format --write .",
    "gen:icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
