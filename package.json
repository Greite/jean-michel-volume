{
  "name": "jean-michel-volume",
  "version": "2.0.2",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "sharp"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prelint": "next typegen",
    "lint": "bun run tsc && bun run biome:check && bun run biome:format",
    "tsc": "tsc --noEmit --pretty",
    "biome:check": "biome check .",
    "biome:check:write": "biome check --write .",
    "biome:format:write": "biome format --write .",
    "biome:format": "biome format .",
    "biome:write": "biome check --write . && biome format --write .",
    "gen:icons": "node scripts/generate-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
